@page
@model LoginModel
@{
    ViewData["Title"] = "Login"; Layout = "_Layout";
}

<div class="auth-wrapper">
    <div class="auth-card">
        <div class="text-center mb-4">
            <div style="font-size:2.5rem;">🔐</div>
            <h1>Welcome Back</h1>
            <p>Sign in to your VOSG-NKBD account</p>
        </div>
        <form id="account" method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2" role="alert"></div>
            <div class="mb-3">
                <label asp-for="Input.Email" class="form-label">Email Address</label>
                <input asp-for="Input.Email" class="form-control" placeholder="your@email.com" autocomplete="username" />
                <span asp-validation-for="Input.Email" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Input.Password" class="form-label">Password</label>
                <input asp-for="Input.Password" class="form-control" placeholder="••••••••" autocomplete="current-password" />
                <span asp-validation-for="Input.Password" class="text-danger small"></span>
            </div>
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div class="form-check">
                    <input class="form-check-input" asp-for="Input.RememberMe" />
                    <label class="form-check-label small" asp-for="Input.RememberMe">Remember me</label>
                </div>
                <a asp-page="./ForgotPassword" class="small">Forgot password?</a>
            </div>
            <button type="submit" class="w-100 btn btn-primary btn-lg">
                <i class="bi bi-box-arrow-in-right me-1"></i>Login
            </button>
        </form>
        <hr class="my-3" />
        <p class="text-center text-muted small mb-0">
            Don't have an account?
            <a asp-page="./Register" class="fw-semibold">Register here</a>
        </p>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}