﻿@Model VOSG_NKBD.Models.Activity

@{
    ViewData["Title"] = "Activity Confirmation";
}

<div class="container mt-5" style="max-width: 600px;">
    <div class="card shadow p-4">
        <h1 class="text-success mb-4">Activity Confirmed!</h1>
        <p>Thank you for your choosing. Here are the details:</dt>

        <dl class="row">
            <dt class="col-sm-4 fw-semibold">Activity Date</dt>
            <dd class="col-sm-8">@Model.BookingDate.ToString("dddd, MMMM dd, yyyy")</dd>

            <dt class="col-sm-4 fw-semibold">Start Time</dt>
            <dd class="col-sm-8">@Model.StartTime.ToString(@"hh\:mm")</dd>

            <dt class="col-sm-4 fw-semibold">End Time</dt>
            <dd class="col-sm-8">@Model.EndTime.ToString(@"hh\:mm")</dd>

            <dt class="col-sm-4 fw-semibold">Place</dt>
            <dd class="col-sm-8">@Model.PlaceName</dd>

            <dt class="col-sm-4 fw-semibold">Total Price</dt>
            <dd class="col-sm-8">$@Model.TotalPrice</dd>
        </dl>

        <a asp-action="Index" class="w-100 btn btn-lg btn-secondary mt-2">
            <i class="bi bi-arrow-left-circle me-1"></i>
            Back to Activities
        </a>
    </div>
</div>
