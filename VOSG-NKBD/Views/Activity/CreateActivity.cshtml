@using System.Security.Claims
@model VOSG_NKBD.Models.Activity

@{
    ViewData["Title"] = "Create Activity";
}
public class Activitiy
{

<h1 class="text-center mt-5">@ViewData["Title"]</h1>

<div class="center-container">
    <div class="center-inner" style="max-width: 900px;">

        <form asp-action="Create" method="post">
            <h2 class="text-center mb-4">Enter activity details</h2>
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

            <div class="row g-3">
                @if (User.IsInRole("Admin"))
                {
                    <div class="col-md-6">
                        <div class="form-floating">
                            <select asp-for="VOSG_NKBDUserId" class="form-select" asp-items="ViewBag.VOSG_NKBDUserId"></select>
                            <label asp-for="VOSG_NKBDUserId">User</label>
                        </div>
                    </div>
                }

                <div class="col-md-6">
                    <div class="form-floating">
                        <select asp-for="PlaceID" class="form-select" id="PlaceID" name="PlaceID" aria-label="Select Place">
                            <option value="" selected disabled>Select Place</option>
                            @foreach (var place in ViewBag.Places)
                            {
                                <option value="@place.PlaceID" data-price="@place.Price">@place.PlaceName</option>
                            }
                        </select>
                        <label asp-for="PlaceID">Place</label>
                        <span asp-validation-for="PlaceID" class="text-danger"></span>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="form-floating">
                        <input asp-for="Date" class="form-control" type="date" min="@DateTime.Now.AddDays(1).ToString("yyyy-MM-dd")" />
                        <label asp-for="Date"> Date</label>
                        <span asp-validation-for="Date" class="text-danger"></span>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="form-floating">
                        <input asp-for="StartTime" class="form-control" type="time" id="StartTime" name="StartTime" />
                        <label asp-for="StartTime">Start Time</label>
                        <span asp-validation-for="StartTime" class="text-danger"></span>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="form-floating">
                        <input asp-for="EndTime" class="form-control" type="time" id="EndTime" name="EndTime" />
                        <label asp-for="EndTime">End Time</label>
                        <span asp-validation-for="EndTime" class="text-danger"></span>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="form-floating">
                        <input asp-for="TotalPrice" class="form-control" id="TotalPrice" name="TotalPrice" readonly value="0.00" />
                        <label asp-for="TotalPrice">Total Price ($)</label>
                        <span asp-validation-for="TotalPrice" class="text-danger"></span>
                    </div>
                </div>
            </div>

            @if (!User.IsInRole("Admin"))
            {
                <input type="hidden" asp-for="VOSG_NKBDUserId" value="@User.FindFirstValue(System.Security.Claims.ClaimTypes.NameIdentifier)" />
            
            }

            <div class="mt-4">
                <button type="submit" class="w-100 btn btn-lg btn-success">Create Activity</button>
                <a asp-controller="Locations" asp-action="Index" class="w-100 btn btn-lg btn-secondary mt-2">
                    <i class="bi bi-arrow-left-circle me-1"></i> Back to List
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const courtSelect = document.getElementById('CourtID');
            const equipmentSelect = document.getElementById('EquipmentID');
            const startTimeInput = document.getElementById('StartTime');
            const endTimeInput = document.getElementById('EndTime');
            const totalPriceInput = document.getElementById('TotalPrice');

            function calculatePrice() {
                const courtOption = courtSelect.selectedOptions[0];
                const equipmentOption = equipmentSelect.selectedOptions[0];

                const courtPricePerHour = courtOption ? parseFloat(courtOption.dataset.price) || 0 : 0;
                const equipmentPrice = equipmentOption ? parseFloat(equipmentOption.dataset.price) || 0 : 0;

                const start = startTimeInput.value;
                const end = endTimeInput.value;

                if (!start || !end) {
                    totalPriceInput.value = '';
                    return;
                }

                const startDate = new Date(`1970-01-01T${start}:00`);
                const endDate = new Date(`1970-01-01T${end}:00`);

                if (endDate <= startDate) {
                    totalPriceInput.value = '';
                    return;
                }

                const durationHours = (endDate - startDate) / 1000 / 60 / 60;
                const total = durationHours * courtPricePerHour + equipmentPrice;

                totalPriceInput.value = total.toFixed(2);
            }

            courtSelect.addEventListener('change', calculatePrice);
            equipmentSelect.addEventListener('change', calculatePrice);
            startTimeInput.addEventListener('change', calculatePrice);
            endTimeInput.addEventListener('change', calculatePrice);
        });
    </script>
}