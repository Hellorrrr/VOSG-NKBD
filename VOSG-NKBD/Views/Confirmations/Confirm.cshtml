@model VOSG_NKBD.Models.Confirmation
@{
    ViewData["Title"] = "Confirm Booking";
}

<div class="container py-4">
    <div class="row g-4 justify-content-center">
        <div class="col-lg-7">
            <div class="vosg-card">
                <h2 class="section-title mb-4">✅ Confirm <span>Booking</span></h2>
                <p class="text-muted mb-4">Please review your booking details below before confirming.</p>
                <form asp-action="Confirm" method="post">
                    <input type="hidden" asp-for="PlaceID" />
                    <input type="hidden" asp-for="StartTime" />
                    <input type="hidden" asp-for="EndTime" />
                    <input type="hidden" asp-for="TotalPrice" />
                    <div class="row g-3 mb-4">
                        <div class="col-sm-6">
                            <div class="p-3 rounded" style="background:var(--gray-100);">
                                <small class="text-muted d-block">Location</small>
                                <strong>@Model.Place?.Location?.LocationName</strong>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="p-3 rounded" style="background:var(--gray-100);">
                                <small class="text-muted d-block">Section / Place</small>
                                <strong>@Model.Place?.PlaceName</strong>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="p-3 rounded" style="background:var(--gray-100);">
                                <small class="text-muted d-block">Start Time</small>
                                <strong>@Model.StartTime.ToString("ddd dd MMM yyyy, HH:mm")</strong>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="p-3 rounded" style="background:var(--gray-100);">
                                <small class="text-muted d-block">End Time</small>
                                <strong>@Model.EndTime.ToString("ddd dd MMM yyyy, HH:mm")</strong>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="p-3 rounded" style="background:var(--gray-100);">
                                <small class="text-muted d-block">Duration</small>
                                <strong>@((Model.EndTime - Model.StartTime).TotalHours.ToString("N1")) hours</strong>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="p-3 rounded" style="background:var(--gray-100);">
                                <small class="text-muted d-block">City</small>
                                <strong>@Model.Place?.Location?.City</strong>
                            </div>
                        </div>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary flex-fill">
                            <i class="bi bi-check-circle me-1"></i>Confirm Booking
                        </button>
                        <a asp-action="Book" asp-route-id="@Model.PlaceID" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left me-1"></i>Back
                        </a>
                    </div>
                </form>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="booking-summary">
                <div style="background:linear-gradient(135deg,var(--primary),var(--accent));height:160px;border-radius:8px;display:flex;align-items:center;justify-content:center;margin-bottom:1rem;">
                    <i class="bi bi-building text-white" style="font-size:3rem;"></i>
                </div>
                <h5 class="fw-bold mb-3">Booking Summary</h5>
                <div class="summary-row"><span>Location</span><strong>@Model.Place?.Location?.LocationName</strong></div>
                <div class="summary-row"><span>Section</span><strong>@Model.Place?.PlaceName</strong></div>
                <div class="summary-row"><span>Date</span><strong>@Model.StartTime.ToString("dd MMM yyyy")</strong></div>
                <div class="summary-row"><span>Duration</span><strong>@((Model.EndTime - Model.StartTime).TotalHours.ToString("N1")) hrs</strong></div>
                <div class="summary-row summary-total"><span>Total Price</span><strong>$@Model.TotalPrice.ToString("N2") NZD</strong></div>
            </div>
        </div>
    </div>
</div>
