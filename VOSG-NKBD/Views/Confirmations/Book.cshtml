@model VOSG_NKBD.Models.Confirmation
@{
    ViewData["Title"] = "Book a Venue";
}

<div class="container py-4">
    <div class="row g-4 justify-content-center">
        <div class="col-lg-7">
            <div class="vosg-card">
                <h2 class="section-title mb-4">📅 Book a <span>Venue</span></h2>
                <form asp-action="Book" method="post">
                    <input type="hidden" asp-for="PlaceID" />
                    <input type="hidden" asp-for="TotalPrice" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                    <div class="mb-3">
                        <label class="form-label">Location</label>
                        <input type="text" class="form-control" value="@Model.Place?.Location?.LocationName" readonly />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Section / Place</label>
                        <input type="text" class="form-control" value="@Model.Place?.PlaceName" readonly />
                    </div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="StartTime" class="form-label"></label>
                            <input asp-for="StartTime" type="datetime-local" class="form-control" />
                            <span asp-validation-for="StartTime" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="EndTime" class="form-label"></label>
                            <input asp-for="EndTime" type="datetime-local" class="form-control" />
                            <span asp-validation-for="EndTime" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="mb-3 mt-3">
                        <label class="form-label">City</label>
                        <input type="text" class="form-control" value="@Model.Place?.Location?.City" readonly />
                    </div>
                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary flex-fill">
                            <i class="bi bi-arrow-right-circle me-1"></i>Continue to Confirm
                        </button>
                        <a asp-controller="Locations" asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="booking-summary">
                <div style="background:linear-gradient(135deg,var(--primary),var(--accent));height:160px;border-radius:8px;display:flex;align-items:center;justify-content:center;margin-bottom:1rem;">
                    <i class="bi bi-building text-white" style="font-size:3rem;"></i>
                </div>
                <h5 class="fw-bold mb-3">Booking Summary</h5>
                <div class="summary-row"><span>Location</span><strong>@Model.Place?.Location?.LocationName</strong></div>
                <div class="summary-row"><span>Section</span><strong>@Model.Place?.PlaceName</strong></div>
                <div class="summary-row"><span>City</span><strong>@Model.Place?.Location?.City</strong></div>
                <div class="summary-row summary-total"><span>Total Price</span><strong>$@Model.Place?.Price.ToString("N2") NZD</strong></div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
