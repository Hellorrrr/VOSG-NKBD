@model VOSG_NKBD.Data.PaginatedList<VOSG_NKBD.Models.Location>
@{
    ViewData["Title"] = "Locations";
    var sortOrder = ViewData["CurrentSort"]?.ToString();
    var filter = ViewData["CurrentFilter"]?.ToString();
}

<div class="container py-4">
    <div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-2">
        <div>
            <h1 class="section-title mb-0">📍 Location <span>Management</span></h1>
            <small class="text-muted">@Model.Count total results</small>
        </div>
        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-circle me-1"></i>+ Create New
            </a>
        }
    </div>

    <form method="get" class="mb-4">
        <div class="input-group" style="max-width:420px;">
            <input type="text" name="searchString" value="@filter"
                   class="form-control" placeholder="Search by name, address or city…" />
            <button type="submit" class="btn btn-primary"><i class="bi bi-search"></i></button>
            @if (!string.IsNullOrEmpty(filter))
            {
                <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-x"></i></a>
            }
        </div>
        <input type="hidden" name="sortOrder" value="@sortOrder" />
    </form>

    <div class="vosg-table">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>
                        <a asp-action="Index" asp-route-sortOrder="@ViewData["NameSort"]"
                               asp-route-currentFilter="@filter" class="sort-link">
                            Location Name <i class="bi bi-arrow-down-up ms-1"></i>
                        </a>
                    </th>
                    <th>Address</th>
                    <th>Suburb</th>
                    <th>
                        <a asp-action="Index" asp-route-sortOrder="@ViewData["CitySort"]"
                               asp-route-currentFilter="@filter" class="sort-link">
                            City <i class="bi bi-arrow-down-up ms-1"></i>
                        </a>
                    </th>
                    <th>Country</th>
                    <th>Postal Code</th>
                    <th>Phone Number</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var loc in Model)
                {
                    <tr>
                        <td class="fw-semibold">@loc.LocationName</td>
                        <td>@loc.Address</td>
                        <td>@loc.Suburb</td>
                        <td>@loc.City</td>
                        <td>@loc.Country</td>
                        <td>@loc.PostalCode</td>
                        <td>@loc.PhoneNumber</td>
                        <td class="text-center">
                            <div class="d-flex gap-1 justify-content-center">
                                <a asp-action="Details" asp-route-id="@loc.LocationsID"
                                       class="btn btn-sm btn-outline-primary" title="Show Info">
                                    <i class="bi bi-eye"></i>
                                </a>
                                @if (User.IsInRole("Admin"))
                                {
                                    <a asp-action="Edit" asp-route-id="@loc.LocationsID"
                                           class="btn btn-sm btn-outline-secondary" title="Edit">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@loc.LocationsID"
                                           class="btn btn-sm btn-outline-danger" title="Delete">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                }
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="8" class="text-center text-muted py-4">No locations found.</td></tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.TotalPages > 1)
    {
        <nav class="mt-3">
            <ul class="pagination justify-content-center">
                <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                    <a class="page-link" asp-action="Index"
                           asp-route-sortOrder="@sortOrder"
                           asp-route-pageNumber="@(Model.PageIndex - 1)"
                           asp-route-currentFilter="@filter">
                        <i class="bi bi-chevron-left"></i>
                    </a>
                </li>
                @for (var i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                        <a class="page-link" asp-action="Index"
                           asp-route-sortOrder="@sortOrder"
                           asp-route-pageNumber="@i"
                           asp-route-currentFilter="@filter">@i</a>
                    </li>
                }
                <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                    <a class="page-link" asp-action="Index"
                           asp-route-sortOrder="@sortOrder"
                           asp-route-pageNumber="@(Model.PageIndex + 1)"
                           asp-route-currentFilter="@filter">
                        <i class="bi bi-chevron-right"></i>
                    </a>
                </li>
            </ul>
        </nav>
    }
</div>
